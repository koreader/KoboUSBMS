#: usbms.c:1367
msgid "USB Mass Storage"
msgstr "Penyimpanan USB"

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:1424
msgid ""
"´ü▒ Please disable USBNet manually!\n"
"Press the power button to exit."
msgstr ""
"´ü▒ Nonaktifkan USBNet secara manual!\n"
"Tekan tombol power untuk keluar."

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:1436
msgid ""
"´ü▒ Please disable USBSerial manually!\n"
"Press the power button to exit."
msgstr ""
"´ü▒ Nonaktifkan USBSerial secara manual!\n"
"Tekan tombol power untuk keluar."

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:1468 usbms.c:1488
msgid ""
"´ü▒ Please disable your custom USB gadget manually!\n"
"Press the power button to exit."
msgstr ""
"´ü▒ Nonaktifkan gawai USB custom Anda secara manual!\n"
"Tekan tombol power untuk keluar."

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:1508
msgid ""
"´ü▒ Please take the device out of the PowerCover!\n"
"Press the power button to exit."
msgstr ""
"´ü▒ Lepas gawai dari PowerCover!\n"
"Tekan tombol power untuk keluar."

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:1543
msgid "´ü▒ Filesystem is busy! Offending processes:"
msgstr "´ü▒ Filesystem sibuk! Proses penyebab:"

#. @translators: First unicode codepoint is an icon, leave it as-is. fuser is a program name, leave it as-is.
#: usbms.c:1578
msgid "´ü▒ The fuser script failed!"
msgstr "´ü▒ Fuser script gagal!"

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:1588
msgid "´ü▒ Could not run the fuser script!"
msgstr "´ü▒ Tidak bisa menjalankan fuser script!"

#: usbms.c:1594
msgid "Press the power button to exit."
msgstr "Tekan tombol power untuk keluar."

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:1657 usbms.c:1780
msgid "´ü▒ The device will shut down in 90 sec."
msgstr "´ü▒ Perangkat akan mati dalam 90 detik."

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:1662 usbms.c:1785
msgid "´üÜ KOReader will now restartÔÇª"
msgstr "´üÜ KOReader akan nyala ulangÔÇª"

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:1704
msgid ""
"´üÜ Gave up after 30 sec.\n"
"The device will shut down in 90 sec."
msgstr ""
"´üÜ Gagal setelah 30 detik.\n"
"Perangkat akan mati dalam 90 detik."

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:1709
msgid ""
"´üÜ Gave up after 30 sec.\n"
"KOReader will now restartÔÇª"
msgstr ""
"´üÜ Batal setelah 30 detik.\n"
"KOReader akan restart sekarangÔÇª"

#: usbms.c:1732
msgid ""
"Waiting to be plugged inÔÇª\n"
"Or, press the power button to exit."
msgstr ""
"Menunggu tersambungÔÇª\n"
"Atau tekan tombol power untuk keluar."

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:1809
msgid ""
"´ü▒ The device was plugged into a plain power source, not a USB host!\n"
"The device will shut down in 90 sec."
msgstr ""
"´ü▒ Perangkat tersambung ke pengisi daya, bukan ke USB host!\n"
"Perangkat akan mati dalam 90 detik."

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:1814
msgid ""
"´ü▒ The device was plugged into a plain power source, not a USB host!\n"
"KOReader will now restartÔÇª"
msgstr ""
"´ü▒ Perangkat tersambung ke pengisi daya, bukan ke USB host!\n"
"KOReader akan menyala ulangÔÇª"

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:1906
msgid ""
"´üÜ Gave up after 60 sec.\n"
"The device will shut down in 90 sec."
msgstr ""
"´üÜ Gagal setelah 60 detik.\n"
"Perangkat akan mati dalam 90 detik."

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:1911
msgid ""
"´üÜ Gave up after 60 sec.\n"
"KOReader will now restartÔÇª"
msgstr ""
"´üÜ Gagal setelah 60 detik.\n"
"KOReader akan restart sekarangÔÇª"

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:2048
msgid ""
"´ü▒ The device is plugged into a plain power source, not a USB host!\n"
"The device will shut down in 90 sec."
msgstr ""
"´ü▒ Perangkat tersambung ke pengisi daya, bukan ke USB host!\n"
"Perangkat akan mati dalam 90 detik."

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:2053
msgid ""
"´ü▒ The device is plugged into a plain power source, not a USB host!\n"
"KOReader will now restartÔÇª"
msgstr ""
"´ü▒ Perangkat tersambung ke pengisi daya, bukan ke USB host!\n"
"Perangkat akan restart sekarangÔÇª"

#: usbms.c:2074
msgid "Starting USBMS sessionÔÇª"
msgstr "Memulai sesi USBMSÔÇª"

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:2106
msgid ""
"´ü▒ Could not start the USBMS session!\n"
"The device will shut down in 90 sec."
msgstr ""
"´ü▒ Tidak bisa memulai sesi USBMS!\n"
"Perangkat akan mati dalam 90 detik."

#: usbms.c:2124
msgid ""
"USBMS session in progress.\n"
"Please eject your device safely before unplugging it."
msgstr ""
"Sesi USBMS sedang berlangsung.\n"
"Harap lepaskan perangkat Anda dengan aman sebelum mencabutnya."

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:2241
msgid ""
"´ü▒ Could not detect an unplug event!\n"
"The device will shut down in 90 sec."
msgstr ""
"´ü▒ Peristiwa pencabutan tidak terdeteksi!\n"
"Perangkat akan mati dalam 90 detik."

#: usbms.c:2251
msgid "Ending USBMS sessionÔÇª"
msgstr "Mengakhiri sesi USBMSÔÇª"

#. @translators: First Unicode codepoint is an icon, leave it as-is.
#: usbms.c:2276
msgid ""
"´ü▒ Could not end the USBMS session!\n"
"The device will shut down in 90 sec."
msgstr ""
"´ü▒ Tidak dapat mengakhiri sesi USBMS!\n"
"Perangkat akan mati dalam 90 detik."

#: usbms.c:2416
msgid ""
"Done!\n"
"KOReader will now restartÔÇª"
msgstr ""
"Selesai!\n"
"KOReader akan restart sekarangÔÇª"
