#: usbms.c:1367
msgid "USB Mass Storage"
msgstr "Memoria di massa USB"

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:1424
msgid ""
"пҒұ Please disable USBNet manually!\n"
"Press the power button to exit."
msgstr ""
"пҒұ Disattiva manualmente USBNet!\n"
"Premi il pulsante di accensione per uscire."

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:1436
msgid ""
"пҒұ Please disable USBSerial manually!\n"
"Press the power button to exit."
msgstr ""
"пҒұ Disattiva manualmente USBSerial!\n"
"Premi il pulsante di accensione per uscire."

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:1468 usbms.c:1488
msgid ""
"пҒұ Please disable your custom USB gadget manually!\n"
"Press the power button to exit."
msgstr ""
"пҒұ Disattiva manualmente il tuo gadget USB personalizzato!\n"
"Premi il pulsante di accensione per uscire."

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:1508
msgid ""
"пҒұ Please take the device out of the PowerCover!\n"
"Press the power button to exit."
msgstr ""
"пҒұ Togli il dispositivo dalla PowerCover!\n"
"Premi il pulsante di accensione per uscire."

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:1543
msgid "пҒұ Filesystem is busy! Offending processes:"
msgstr "пҒұ Il file system ГЁ occupato! Processi che interferiscono:"

#. @translators: First unicode codepoint is an icon, leave it as-is. fuser is a program name, leave it as-is.
#: usbms.c:1578
msgid "пҒұ The fuser script failed!"
msgstr "пҒұ Lo script fusore ГЁ fallito!"

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:1588
msgid "пҒұ Could not run the fuser script!"
msgstr "пҒұ Impossibile eseguire lo script di unione!"

#: usbms.c:1594
msgid "Press the power button to exit."
msgstr "Premi il pulsante di accensione per uscire."

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:1657 usbms.c:1780
msgid "пҒұ The device will shut down in 90 sec."
msgstr "пҒұ Il dispositivo si spegnerГ  in 90 secondi."

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:1662 usbms.c:1785
msgid "пҒҡ KOReader will now restartвҖҰ"
msgstr "пҒҡ KOReader verrГ  riavviatoвҖҰ"

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:1704
msgid ""
"пҒҡ Gave up after 30 sec.\n"
"The device will shut down in 90 sec."
msgstr ""
"пҒҡ Nessun risultato dopo 30 secondi.\n"
"Il dispositivo si spegnerГ  tra 90 secondi."

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:1709
msgid ""
"пҒҡ Gave up after 30 sec.\n"
"KOReader will now restartвҖҰ"
msgstr ""
"пҒҡ Nessun risultato dopo 30 secondi.\n"
"KOReader verrГ  riavviato oraвҖҰ"

#: usbms.c:1732
msgid ""
"Waiting to be plugged inвҖҰ\n"
"Or, press the power button to exit."
msgstr ""
"In attesa di essere collegato...\n"
"In alternativa, premi il pulsante di alimentazione per uscire."

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:1809
msgid ""
"пҒұ The device was plugged into a plain power source, not a USB host!\n"
"The device will shut down in 90 sec."
msgstr ""
"пҒұ Il dispositivo ГЁ stato collegato a una normale fonte di alimentazione, non "
"a un host USB!\n"
"Il dispositivo si spegnerГ  tra 90 secondi."

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:1814
msgid ""
"пҒұ The device was plugged into a plain power source, not a USB host!\n"
"KOReader will now restartвҖҰ"
msgstr ""
"пҒұ Il dispositivo ГЁ stato collegato a una normale fonte di alimentazione, non "
"a un host USB!\n"
"KOReader verrГ  riavviato oraвҖҰ"

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:1906
msgid ""
"пҒҡ Gave up after 60 sec.\n"
"The device will shut down in 90 sec."
msgstr ""
"пҒҡ Nessun risultato dopo 60 secondi.\n"
"Il dispositivo si spegnerГ  tra 90 secondi."

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:1911
msgid ""
"пҒҡ Gave up after 60 sec.\n"
"KOReader will now restartвҖҰ"
msgstr ""
"пҒҡ Nessun risultato dopo 60 sec.\n"
"KOReader verrГ  riavviato oraвҖҰ"

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:2048
msgid ""
"пҒұ The device is plugged into a plain power source, not a USB host!\n"
"The device will shut down in 90 sec."
msgstr ""
"пҒұ Il dispositivo ГЁ collegato a un normale alimentatore, non a un host USB!\n"
"Il dispositivo si spegnerГ  tra 90 secondi."

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:2053
msgid ""
"пҒұ The device is plugged into a plain power source, not a USB host!\n"
"KOReader will now restartвҖҰ"
msgstr ""
"пҒұ Il dispositivo ГЁ collegato a un normale alimentatore, non a un host USB!\n"
"KOReader verrГ  riavviato oraвҖҰ"

#: usbms.c:2074
msgid "Starting USBMS sessionвҖҰ"
msgstr "Avvio sessione USBMSвҖҰ"

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:2106
msgid ""
"пҒұ Could not start the USBMS session!\n"
"The device will shut down in 90 sec."
msgstr ""
"пҒұ Impossibile avviare la sessione USBMS!\n"
"Il dispositivo si spegnerГ  entro 90 secondi."

#: usbms.c:2124
msgid ""
"USBMS session in progress.\n"
"Please eject your device safely before unplugging it."
msgstr ""
"Sessione USBMS in corso.\n"
"Espelli il dispositivo in modo sicuro prima di scollegarlo."

#. @translators: First unicode codepoint is an icon, leave it as-is.
#: usbms.c:2241
msgid ""
"пҒұ Could not detect an unplug event!\n"
"The device will shut down in 90 sec."
msgstr ""
"пҒұ Impossibile rilevare l'evento di scollegamento!\n"
"Il dispositivo si spegnerГ  entro 90 secondi."

#: usbms.c:2251
msgid "Ending USBMS sessionвҖҰ"
msgstr "Chiusura della sessione USBMS in corsoвҖҰ"

#. @translators: First Unicode codepoint is an icon, leave it as-is.
#: usbms.c:2276
msgid ""
"пҒұ Could not end the USBMS session!\n"
"The device will shut down in 90 sec."
msgstr ""
"пҒұ Impossibile terminare la sessione USBMS!\n"
"Il dispositivo si spegnerГ  entro 90 secondi."

#: usbms.c:2416
msgid ""
"Done!\n"
"KOReader will now restartвҖҰ"
msgstr ""
"Fatto!\n"
"KOReader ora verrГ  riavviatoвҖҰ"

